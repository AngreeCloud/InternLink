rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function pendingRegistrationPath(userId) {
      return /databases/$(database)/documents/pendingRegistrations/$(userId);
    }

    function coursePath(courseId) {
      return /databases/$(database)/documents/courses/$(courseId);
    }

    function currentUserDoc() {
      return get(userPath(request.auth.uid));
    }

    function currentUserExists() {
      return isSignedIn() && exists(userPath(request.auth.uid));
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function pendingRegistrationExists(userId) {
      return exists(pendingRegistrationPath(userId));
    }

    function pendingRegistrationData(userId) {
      return get(pendingRegistrationPath(userId)).data;
    }

    function courseExists(courseId) {
      return courseId is string
        && courseId.size() > 0
        && exists(coursePath(courseId));
    }

    function courseData(courseId) {
      return get(coursePath(courseId)).data;
    }

    function isCourseFromSchool(courseId, schoolId) {
      return courseExists(courseId)
        && schoolId is string
        && schoolId.size() > 0
        && courseData(courseId).schoolId == schoolId;
    }

    function isSchoolAdmin() {
      return currentUserExists()
        && currentUserData().role == "admin_escolar";
    }

    function isSchoolAdminFor(schoolId) {
      return isSchoolAdmin()
        && currentUserData().schoolId == schoolId;
    }

    function isProfessor() {
      return currentUserExists()
        && currentUserData().role == "professor"
        && currentUserData().estado == "ativo";
    }

    function isProfessorFor(schoolId) {
      return isProfessor()
        && currentUserData().schoolId == schoolId;
    }

    function isTutor() {
      return currentUserExists()
        && currentUserData().role == "tutor";
    }

    function tutorEmailMatches(emailValue) {
      return isTutor()
        && emailValue is string
        && currentUserData().email is string
        && (
          emailValue == currentUserData().email
          || emailValue.lower() == currentUserData().email.lower()
        );
    }

    function isTutorInviteReceiver() {
      return isSignedIn()
        && (
          resource.data.email == request.auth.token.email
          || (
            resource.data.email is string
            && request.auth.token.email is string
            && resource.data.email.lower() == request.auth.token.email.lower()
          )
          || (
            resource.data.emailNormalized is string
            && request.auth.token.email is string
            && resource.data.emailNormalized == request.auth.token.email.lower()
          )
        );
    }

    function isTutorInviteReceiverCreate() {
      return isSignedIn()
        && (
          request.resource.data.email == request.auth.token.email
          || (
            request.resource.data.email is string
            && request.auth.token.email is string
            && request.resource.data.email.lower() == request.auth.token.email.lower()
          )
          || (
            request.resource.data.emailNormalized is string
            && request.auth.token.email is string
            && request.resource.data.emailNormalized == request.auth.token.email.lower()
          )
        );
    }

    function isProfessorPendingFor(schoolId, userId) {
      return isSelf(userId)
        && currentUserExists()
        && currentUserData().role == "professor"
        && currentUserData().schoolId == schoolId
        && currentUserData().estado == "pendente";
    }

    function isSelfUserDocImmutable() {
      return !request.resource.data
        .diff(resource.data)
        .affectedKeys()
        .hasAny(["role", "estado", "schoolId", "courseId"]);
    }

    function isProfessorSchoolReRequestUpdate() {
      return resource.data.role == "professor"
        && request.resource.data.role == "professor"
        && resource.data.estado in ["pendente", "recusado", "removido", "inativo"]
        && request.resource.data.estado == "pendente"
        && request.resource.data.schoolId is string
        && request.resource.data.schoolId.size() > 0
        && request.resource.data.courseId is string
        && request.resource.data.courseId.size() > 0
        && isCourseFromSchool(request.resource.data.courseId, request.resource.data.schoolId)
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(["estado", "schoolId", "escola", "courseId", "curso", "reviewedAt", "reviewedBy", "updatedAt"])
        && (!request.resource.data.keys().hasAny(["reviewedAt"]) || request.resource.data.reviewedAt == null)
        && (!request.resource.data.keys().hasAny(["reviewedBy"]) || request.resource.data.reviewedBy == null);
    }

    function isStudentSchoolReRequestUpdate() {
      return resource.data.role == "aluno"
        && request.resource.data.role == "aluno"
        && resource.data.estado in ["pendente", "inativo", "removido", "rejeitado"]
        && request.resource.data.estado == "pendente"
        && request.resource.data.schoolId is string
        && request.resource.data.schoolId.size() > 0
        && request.resource.data.courseId is string
        && request.resource.data.courseId.size() > 0
        && isCourseFromSchool(request.resource.data.courseId, request.resource.data.schoolId)
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(["estado", "schoolId", "escola", "courseId", "curso", "reviewedAt", "reviewedBy", "updatedAt"])
        && (!request.resource.data.keys().hasAny(["reviewedAt"]) || request.resource.data.reviewedAt == null)
        && (!request.resource.data.keys().hasAny(["reviewedBy"]) || request.resource.data.reviewedBy == null);
    }

    function isProfessorAssignedToCourse(courseId) {
      return courseExists(courseId)
        && courseData(courseId).schoolId == currentUserData().schoolId
        && (
          (courseData(courseId).courseDirectorId is string && courseData(courseId).courseDirectorId == request.auth.uid)
          || (courseData(courseId).teacherIds is list && courseData(courseId).teacherIds.hasAny([request.auth.uid]))
          || (courseData(courseId).supportingTeacherIds is list && courseData(courseId).supportingTeacherIds.hasAny([request.auth.uid]))
        );
    }

    function professorCanManageStudentCourse() {
      return resource.data.courseId is string
        && resource.data.courseId.size() > 0
        && request.resource.data.courseId is string
        && request.resource.data.courseId.size() > 0
        && isProfessorAssignedToCourse(resource.data.courseId)
        && isProfessorAssignedToCourse(request.resource.data.courseId);
    }

    function professorCanUpdateStudentFields() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.role == "aluno"
        && request.resource.data.schoolId == resource.data.schoolId
        && professorCanManageStudentCourse()
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(["estado", "courseId", "curso", "updatedAt"]);
    }

    function isSchoolAdminViewingProfessorPendingRegistration() {
      return isSchoolAdmin()
        && resource.data.role == "professor"
        && resource.data.estado == "pendente"
        && resource.data.schoolId == currentUserData().schoolId;
    }

    function isProfessorPendingRegistrationSchoolChange(userId) {
      return isSelf(userId)
        && resource.data.role == "professor"
        && request.resource.data.role == "professor"
        && resource.data.estado == "pendente"
        && request.resource.data.estado == "pendente"
        && request.resource.data.email == resource.data.email
        && request.resource.data.emailVerified == resource.data.emailVerified
        && request.resource.data.schoolId is string
        && request.resource.data.schoolId.size() > 0
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(["schoolId", "escola", "updatedAt"]);
    }

    function isSchoolAdminPendingRegistrationDecision() {
      return isSchoolAdmin()
        && resource.data.role == "professor"
        && resource.data.schoolId == currentUserData().schoolId
        && request.resource.data.role == resource.data.role
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.email == resource.data.email
        && request.resource.data.emailVerified == resource.data.emailVerified
        && request.resource.data.estado in ["ativo", "recusado"]
        && request.resource.data
          .diff(resource.data)
          .affectedKeys()
          .hasOnly(["estado", "reviewedAt", "reviewedBy"]);
    }

    // USERS
    match /users/{userId} {
      allow read: if isSelf(userId)
        || (currentUserExists()
          && currentUserData().estado == "ativo"
          && (
            resource.data.schoolId == currentUserData().schoolId
            || resource.data.schoolId == currentUserData().escolaId
            || resource.data.escolaId == currentUserData().schoolId
            || resource.data.escolaId == currentUserData().escolaId
          ))
        || (isSchoolAdmin() && resource.data.schoolId == currentUserData().schoolId)
        || (isProfessor() && resource.data.schoolId == currentUserData().schoolId);

      // Criação final de utilizadores vindos de pendingRegistrations (aluno/professor).
      allow create: if (
        isSelf(userId)
        && request.resource.data.role in ["aluno", "professor"]
        && request.resource.data.estado == "pendente"
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == request.auth.token.email_verified
      )
      // Criação final de utilizadores vindos de pendingRegistrations (legado).
      || (
        isSelf(userId)
        && pendingRegistrationExists(userId)
        && request.resource.data.role == pendingRegistrationData(userId).role
        && request.resource.data.estado == pendingRegistrationData(userId).estado
        && request.resource.data.email == pendingRegistrationData(userId).email
        && request.resource.data.emailVerified == request.auth.token.email_verified
        && (
          request.auth.token.email_verified == true
          || (
            pendingRegistrationData(userId).role == "tutor"
            && pendingRegistrationData(userId).estado == "inativo"
          )
        )
      )
      // Registo direto de tutor sem aprovação de escola.
      || (
        isSelf(userId)
        && request.resource.data.role == "tutor"
        && request.resource.data.estado in ["ativo", "inativo"]
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == request.auth.token.email_verified
        && (
          (request.auth.token.email_verified == true && request.resource.data.estado == "ativo")
          || (request.auth.token.email_verified != true && request.resource.data.estado == "inativo")
        )
      );

      // Permite ao próprio editar campos de perfil e re-solicitar acesso (professor removido/recusado).
      allow update: if isSelf(userId)
        && (isSelfUserDocImmutable() || isProfessorSchoolReRequestUpdate() || isStudentSchoolReRequestUpdate());

      // Admin escolar gere utilizadores da própria escola.
      allow update, delete: if isSchoolAdmin()
        && resource.data.schoolId == currentUserData().schoolId;

      // Professor pode aprovar/rejeitar alunos da sua escola (apenas estado).
      allow update: if isProfessor()
        && resource.data.schoolId == currentUserData().schoolId
        && resource.data.role == "aluno"
        && professorCanUpdateStudentFields();
    }

    // REGISTOS PENDENTES (antes da verificação de email)
    match /pendingRegistrations/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.role in ["aluno", "professor", "tutor"]
        && request.resource.data.estado in ["pendente", "inativo"]
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.emailVerified == request.auth.token.email_verified;

      allow read: if isSelf(userId)
        || isSchoolAdminViewingProfessorPendingRegistration();

      allow delete: if isSelf(userId);

      // Professor pendente pode alterar escola de associação mantendo os restantes campos imutáveis.
      allow update: if isProfessorPendingRegistrationSchoolChange(userId)
        || isSchoolAdminPendingRegistrationDecision();
    }

    // SCHOOLS + FOLDERS + PENDING TEACHERS
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if isSchoolAdminFor(schoolId);

      match /folders/{folderId} {
        allow read, write: if isSchoolAdminFor(schoolId);
      }

      match /pendingTeachers/{docId} {
        // Registo inicial do professor pendente (self-service)
        allow create: if isProfessorPendingFor(schoolId, docId)
          && request.resource.data.role == "teacher";

        // Gestão por admin escolar
        allow read, update, delete: if isSchoolAdminFor(schoolId);
      }

      match /approvalHistory/{docId} {
        allow read, create: if isSchoolAdminFor(schoolId);
      }

      match /tutors/{tutorId} {
        allow read: if isSelf(tutorId)
          || (isTutor() && resource.data.tutorId == request.auth.uid)
          || tutorEmailMatches(resource.data.email)
          || isSchoolAdminFor(schoolId)
          || isProfessorFor(schoolId);

        allow create: if isSelf(tutorId)
          && request.resource.data.tutorId == tutorId
          && request.resource.data.schoolId == schoolId
          && request.resource.data.role == "tutor";

        allow update: if isSelf(tutorId)
          || isSchoolAdminFor(schoolId)
          || isProfessorFor(schoolId);

        allow delete: if isSchoolAdminFor(schoolId);
      }
    }

    // GLOBAL COURSES COLLECTION
    match /courses/{courseId} {
      allow read: if true;

      allow create: if isSchoolAdmin()
        && request.resource.data.schoolId == currentUserData().schoolId;

      allow update: if isSchoolAdmin()
        && resource.data.schoolId == currentUserData().schoolId
        && request.resource.data.schoolId == resource.data.schoolId;

      allow delete: if isSchoolAdmin()
        && resource.data.schoolId == currentUserData().schoolId;
    }

    // INTERNSHIP STRUCTURE (usada no dashboard do aluno)
    match /internships/{internshipId} {
      allow read: if isSignedIn()
        && (
          resource.data.studentId == request.auth.uid
          || (resource.data.schoolId != null && isSchoolAdminFor(resource.data.schoolId))
        );

      // TODO: abrir permissões a professor/tutor quando a gestão de estágio for implementada.
      allow create, update, delete: if isSchoolAdmin()
        && request.resource.data.schoolId == currentUserData().schoolId;
    }

    // INTERNSHIP REPORTS
    match /internshipReports/{reportId} {
      allow read: if isSignedIn()
        && (
          resource.data.studentId == request.auth.uid
          || (isTutor() && resource.data.tutorId == request.auth.uid)
          || (resource.data.schoolId != null && isSchoolAdminFor(resource.data.schoolId))
        );

      allow create: if isSignedIn()
        && request.resource.data.studentId == request.auth.uid;

      allow update, delete: if isSignedIn()
        && (
          resource.data.studentId == request.auth.uid
          || (resource.data.schoolId != null && isSchoolAdminFor(resource.data.schoolId))
        );
    }

    // ESTÁGIOS (geridos pelo professor)
    function isEstagioMember(estagioData) {
      return isSignedIn()
        && (
          estagioData.alunoId == request.auth.uid
          || estagioData.professorId == request.auth.uid
          || estagioData.tutorId == request.auth.uid
          || (estagioData.schoolId != null && isSchoolAdminFor(estagioData.schoolId))
        );
    }

    function isEstagioDirector(estagioData) {
      return isSignedIn()
        && estagioData.professorId == request.auth.uid
        && (
          (estagioData.alunoCourseId is string && isCourseDirectorOf(estagioData.alunoCourseId))
          || (estagioData.courseId is string && isCourseDirectorOf(estagioData.courseId))
        );
    }

    function isCourseDirectorOf(courseId) {
      return courseExists(courseId)
        && courseData(courseId).courseDirectorId is string
        && courseData(courseId).courseDirectorId == request.auth.uid;
    }

    match /estagios/{estagioId} {
      allow read: if isEstagioMember(resource.data);

      allow create: if isSignedIn()
        && currentUserExists()
        && currentUserData().role == "professor";

      allow update, delete: if isSignedIn()
        && currentUserExists()
        && currentUserData().role == "professor"
        && resource.data.professorId == request.auth.uid;

      // Sub-coleção de documentos associados ao estágio.
      match /documentos/{documentoId} {
        allow read: if isEstagioMember(get(/databases/$(database)/documents/estagios/$(estagioId)).data);

        // Criação/edição reservada ao Diretor de Curso (via API route com admin SDK).
        // Na UI client-side permitimos o Diretor de Curso (professor + courseDirectorId).
        allow create, update, delete: if isSignedIn()
          && isEstagioDirector(get(/databases/$(database)/documents/estagios/$(estagioId)).data);

        // Histórico imutável de versões.
        match /versoes/{versionId} {
          allow read: if isEstagioMember(get(/databases/$(database)/documents/estagios/$(estagioId)).data);
          allow create: if isSignedIn()
            && isEstagioDirector(get(/databases/$(database)/documents/estagios/$(estagioId)).data);
          allow update, delete: if false;
        }

        // Registo por signatário. Cada utilizador só pode criar a sua própria assinatura.
        match /assinaturas/{signerUid} {
          allow read: if isEstagioMember(get(/databases/$(database)/documents/estagios/$(estagioId)).data);
          allow create: if isSelf(signerUid);
          allow update, delete: if false;
        }
      }

      // Notificações do estágio (apenas o destinatário lê).
      match /notifications/{notifId} {
        allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create, delete: if isSignedIn()
          && isEstagioDirector(get(/databases/$(database)/documents/estagios/$(estagioId)).data);
      }

      // Presenças, sumários e avaliação (estrutura básica para suporte futuro).
      match /presencas/{dateId} {
        allow read: if isEstagioMember(get(/databases/$(database)/documents/estagios/$(estagioId)).data);
        allow write: if isSignedIn()
          && (
            isEstagioDirector(get(/databases/$(database)/documents/estagios/$(estagioId)).data)
            || get(/databases/$(database)/documents/estagios/$(estagioId)).data.tutorId == request.auth.uid
          );
      }

      match /sumarios/{weekId} {
        allow read: if isEstagioMember(get(/databases/$(database)/documents/estagios/$(estagioId)).data);
        allow write: if isSignedIn()
          && (
            isEstagioDirector(get(/databases/$(database)/documents/estagios/$(estagioId)).data)
            || get(/databases/$(database)/documents/estagios/$(estagioId)).data.alunoId == request.auth.uid
            || get(/databases/$(database)/documents/estagios/$(estagioId)).data.tutorId == request.auth.uid
          );
      }

      match /avaliacao/{avalId} {
        allow read: if isEstagioMember(get(/databases/$(database)/documents/estagios/$(estagioId)).data)
          && get(/databases/$(database)/documents/estagios/$(estagioId)).data.alunoId != request.auth.uid;
        allow write: if isSignedIn()
          && (
            isEstagioDirector(get(/databases/$(database)/documents/estagios/$(estagioId)).data)
            || get(/databases/$(database)/documents/estagios/$(estagioId)).data.professorId == request.auth.uid
            || get(/databases/$(database)/documents/estagios/$(estagioId)).data.tutorId == request.auth.uid
          );
      }
    }

    // Assinatura pessoal dos utilizadores (settings privadas).
    match /users/{userId}/settings/{settingId} {
      allow read, write: if isSelf(userId);
    }

    // DOCUMENTOS (geridos pelo professor, lidos por professorId e school admins)
    match /documentos/{documentoId} {
      // TODO: Add tutorId field to documents to enforce tutor access at the database layer.
      // Currently, tutors can read via client-side queries (estagioId), trusting the application layer.
      // Should restrict to: resource.data.tutorId == request.auth.uid && visibilidade allows.
      allow read: if isSignedIn()
        && (
          resource.data.professorId == request.auth.uid
          || (resource.data.schoolId != null && isSchoolAdminFor(resource.data.schoolId))
          || (isTutor() && (resource.data.visibilidade == "tutores" || resource.data.visibilidade == "todos"))
        );

      allow create: if isSignedIn()
        && currentUserExists()
        && currentUserData().role == "professor";

      allow update, delete: if isSignedIn()
        && currentUserExists()
        && currentUserData().role == "professor"
        && resource.data.professorId == request.auth.uid;
    }

    // CONVITES DE TUTOR
    match /chatAccess/{conversationId} {
      allow read: if isSignedIn()
        && resource.data.participants[request.auth.uid] == true;

      allow create: if isSignedIn()
        && request.resource.data.participants[request.auth.uid] == true;

      // Participants map is immutable after creation to prevent privilege escalation.
      allow update: if isSignedIn()
        && resource.data.participants[request.auth.uid] == true
        && request.resource.data.participants == resource.data.participants;

      allow delete: if false;
    }

    // CONVITES DE TUTOR
    match /tutorInvites/{inviteId} {
      allow read: if isSignedIn()
        && (
          resource.data.professorId == request.auth.uid
          || (resource.data.schoolId != null && isSchoolAdminFor(resource.data.schoolId))
          || isTutorInviteReceiver()
        );

      allow create: if isSignedIn()
        && currentUserExists()
        && currentUserData().role == "professor";

      allow update: if (
        isSignedIn()
        && currentUserExists()
        && currentUserData().role == "professor"
        && resource.data.professorId == request.auth.uid
      )
      || (
        isTutorInviteReceiver()
        && request.resource.data.email == resource.data.email
        && (
          !resource.data.keys().hasAny(["emailNormalized"])
          || request.resource.data.emailNormalized == resource.data.emailNormalized
        )
        && request.resource.data.schoolId == resource.data.schoolId
        && request.resource.data.professorId == resource.data.professorId
      );

      allow delete: if isSignedIn()
        && currentUserExists()
        && currentUserData().role == "professor"
        && resource.data.professorId == request.auth.uid;
    }
  }
}
