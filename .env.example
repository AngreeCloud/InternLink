# InternLink - exemplo de variáveis de ambiente
# Copia este ficheiro para .env.local e preenche com os valores do teu projeto Firebase.

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin SDK (server-side) para session cookies
# Obtenha em Firebase Console > Project Settings > Service Accounts > Generate new private key
# Recomendado: colar o conteudo completo do JSON numa unica variavel (sem NEXT_PUBLIC)
# Ex.: {"type":"service_account",...,"private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}
FIREBASE_ADMIN_SERVICE_ACCOUNT_JSON=
# Opcional: URL do Realtime Database (como aparece no snippet de Node.js da Firebase)
FIREBASE_ADMIN_DATABASE_URL=

# Alternativa ao JSON completo (manter apenas se preferires variaveis separadas)
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Importante: usar \n para quebras de linha ao guardar em uma unica linha
FIREBASE_ADMIN_PRIVATE_KEY=

# Opcional: seed automático de admin escolar em ambiente local
# true | false
NEXT_PUBLIC_ENABLE_SEED_ADMIN=false

# Opcional: Google reCAPTCHA v3 — chave do site
# Obtenha em https://www.google.com/recaptcha/admin
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_RECAPTCHA_SECRET_KEY=
# Opcional: score mínimo aceite na validação do v3 (0.0 a 1.0)
RECAPTCHA_MIN_SCORE=0.5